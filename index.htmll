<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GAJAHBOLA</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    background:#000;
    color:#fff;
    font-family:Arial,sans-serif;
}

/* HEADER */
.header{
    background:#111;
    border-bottom:2px solid gold;
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:10px 20px;
}

.logo img{
    height:55px;
    width:auto;
}

.menu{
    display:flex;
    gap:25px;
}

.menu a{
    color:white;
    text-decoration:none;
    font-weight:bold;
}

.menu a:hover{
    color:gold;
}

.action-btn{
    display:flex;
    gap:10px;
}

.login-btn{
    border:1px solid gold;
    color:gold;
    padding:10px 20px;
    border-radius:25px;
    text-decoration:none;
    font-weight:bold;
}

.register-btn{
    background:gold;
    color:black;
    padding:10px 20px;
    border-radius:25px;
    text-decoration:none;
    font-weight:bold;
}

/* HERO */
.hero{
    height:500px;
    background:linear-gradient(#000,#222);
    display:flex;
    flex-direction:column;
    justify-content:center;
    align-items:center;
    text-align:center;
}

.hero h1{
    color:gold;
    font-size:50px;
    margin-bottom:10px;
}

.hero p{
    margin-bottom:25px;
    font-size:18px;
}

.btn{
    background:gold;
    color:black;
    padding:12px 25px;
    border-radius:30px;
    text-decoration:none;
    font-weight:bold;
}

</style>
</head>

<body>

<header class="header">

    <div class="logo">
        <img src="gajahbola-logo.png" alt="GAJAHBOLA">
    </div>

    <nav class="menu">
        <a href="https://gajahbola01.com/sportsbook" target="_blank">Beranda</a>
        <a href="https://gajahbola01.com/sportsbook" target="_blank">Prediksi</a>
        <a href="https://gajahbola01.com/sportsbook" target="_blank">Jadwal</a>
    </nav>

    <div class="action-btn">
        <a href="https://gajahbola01.com/sportsbook" target="_blank" class="login-btn">
            LOGIN
        </a>

        <a href="https://gajahbola01.com/sportsbook" target="_blank" class="register-btn">
            DAFTAR
        </a>
    </div>

</header>

<section class="hero">

    <h1>PREDIKSI SKOR AKURAT</h1>

    <p>Analisa pertandingan terpercaya</p>

    <a href="https://gajahbola01.com/sportsbook"
       target="_blank"
       class="btn">
       MAIN SEKARANG
    </a>

</section>

</body>
</html>
